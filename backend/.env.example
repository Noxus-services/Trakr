# ═══════════════════════════════════════════
# TRAKR PROSPECTOR — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════

# ── Application ─────────────────────────────
APP_NAME=Trakr Prospector
DEBUG=false
# Clé secrète JWT — générez-la avec : openssl rand -hex 32
SECRET_KEY=your-secret-key-change-me-in-production

# ── Base de données PostgreSQL ───────────────
DATABASE_URL=postgresql+asyncpg://trakr:trakr@localhost:5432/trakr_prospector
DATABASE_URL_SYNC=postgresql://trakr:trakr@localhost:5432/trakr_prospector

# ── Redis & Celery ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Scraping — Google Places ──────────────────
# Obtenir sur : https://console.cloud.google.com → Places API
GOOGLE_PLACES_API_KEY=

# ── Scraping — INSEE Sirène ───────────────────
# Obtenir sur : https://api.insee.fr (inscription gratuite)
INSEE_API_KEY=

# ── Enrichissement — Hunter.io ────────────────
# Obtenir sur : https://hunter.io/api
HUNTER_API_KEY=

# ── Enrichissement — Dropcontact ──────────────
# Obtenir sur : https://app.dropcontact.com/settings/api
DROPCONTACT_API_KEY=

# ── Emailing — SendGrid ───────────────────────
# Obtenir sur : https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=prospection@votre-domaine.fr
SENDGRID_FROM_NAME=Équipe Commerciale

# ── Odoo ──────────────────────────────────────
ODOO_URL=https://votre-instance.odoo.com
ODOO_DB=votre_base
ODOO_USERNAME=admin@exemple.fr
ODOO_PASSWORD=votre_mot_de_passe_odoo

# ── Carte — Mapbox ────────────────────────────
# Obtenir sur : https://account.mapbox.com
MAPBOX_TOKEN=

# ── URLs ──────────────────────────────────────
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173
